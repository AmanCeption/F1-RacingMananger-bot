# ─────────────────────────────────────────────
# F1 Management Bot - Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# REQUIRED
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=[123456789]

# DATABASE (PostgreSQL)
# Local: postgresql+asyncpg://user:password@localhost:5432/f1bot
# Render/Railway: paste the connection string they give you (change postgres:// to postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://f1bot:f1bot@localhost:5432/f1bot

# REDIS
# Local: redis://localhost:6379/0
# Render: paste your Redis URL (add rediss:// for TLS)
REDIS_URL=redis://localhost:6379/0

# GAME SETTINGS (optional - these are defaults)
STARTING_BUDGET=100000000
MAX_TEAMS_PER_LEAGUE=20
SEASON_RACES=24
WEEKLY_RESEARCH_POINTS=50
DAILY_REWARD_MONEY=500000
DAILY_REWARD_RP=10

# RACE SCHEDULE (UTC time)
RACE_HOUR=14
RACE_MINUTE=0

# ANTI-CHEAT
COMMAND_COOLDOWN=3
MAX_COMMANDS_PER_MINUTE=20

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
